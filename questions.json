[
  {
    "type": "binomial",
    "template": "A student guesses on {n} multiple choice questions (4 options each). What is P(X={k})?",
    "params": {
      "n": [ 8, 12 ],
      "k": [ 0, 4 ]
    },
    "p": 0.25
  },

  {
    "type": "poisson",
    "template": "Calls arrive at rate λ={lambda} per minute. What is P(X={k})?",
    "params": {
      "lambda": [ 2, 6 ],
      "k": [ 0, 5 ]
    }
  },

  {
    "type": "zscore",
    "template": "Find the z-score when x={x}, μ={mu}, σ={sigma}",
    "params": {
      "x": [ 80, 120 ],
      "mu": [ 90, 110 ],
      "sigma": [ 5, 15 ]
    }
  },

  {
    "type": "normalprob",
    "template": "Find P(Z < {z})",
    "params": {
      "z": [ -2, 2 ]
    }
  }
]